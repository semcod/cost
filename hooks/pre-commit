#!/bin/bash
# AI Cost pre-commit hook
# Automatically updates AI cost badge before each commit

# Get project root
PROJECT_ROOT=$(git rev-parse --show-toplevel)
cd "$PROJECT_ROOT"

# Check if costs is installed (global or in venv)
COSTS_CMD=""
if command -v costs &> /dev/null; then
    COSTS_CMD="costs"
elif [ -f "$PROJECT_ROOT/.venv/bin/costs" ]; then
    COSTS_CMD="$PROJECT_ROOT/.venv/bin/costs"
elif [ -f "$PROJECT_ROOT/venv/bin/costs" ]; then
    COSTS_CMD="$PROJECT_ROOT/venv/bin/costs"
fi

if [ -z "$COSTS_CMD" ]; then
    echo "⚠️  'costs' not found. Install with: pip install -e ."
    exit 0
fi

# Check if pyproject.toml has [tool.costs] configured
if [ -f "pyproject.toml" ] && grep -q "\[tool.costs\]" pyproject.toml; then
    echo "🤖 Updating AI cost badge..."
    
    # Run auto-badge
    $COSTS_CMD auto-badge --repo . --quiet 2>/dev/null || $COSTS_CMD auto-badge --repo .
    
    # Check if README was modified
    if git diff --quiet README.md 2>/dev/null; then
        echo "ℹ️  No changes to README.md"
    else
        echo "✅ AI cost badge updated"
        
        # Stage the updated README
        git add README.md
        
        # Ask if user wants to include it in this commit (only in interactive mode)
        if [ -t 0 ]; then
            read -p "Include badge update in this commit? (y/n) " -n 1 -r
            echo
            if [[ $REPLY =~ ^[Yy]$ ]]; then
                echo "📦 README.md staged with badge update"
            else
                git reset HEAD README.md
                echo "📦 README.md unstaged (badge updated but not committed)"
            fi
        else
            echo "📦 README.md staged with badge update (non-interactive mode)"
        fi
    fi
fi

exit 0
